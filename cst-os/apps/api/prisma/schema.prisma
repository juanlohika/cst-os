// ── Custom Fields System ──────────────────────────────────────────────────────
// Allows admins to define additional fields for any entity type at runtime.

enum FieldType {
  text
  long_text
  number
  decimal
  select
  multi_select
  date
  boolean
  url
  email
  phone
}

model CustomFieldDefinition {
  id         String    @id @default(uuid())
  entityType String    // "client" | "project" | "task" | "user"
  label      String
  fieldKey   String
  fieldType  FieldType @default(text)
  options    Json?     // [{ value: string, label: string, color: string }]
  sortOrder  Int       @default(0)
  isRequired Boolean   @default(false)
  isVisible  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  values CustomFieldValue[]

  @@unique([entityType, fieldKey])
  @@index([entityType])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  fieldId   String
  entityId  String
  value     Json?
  updatedAt DateTime @updatedAt

  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

